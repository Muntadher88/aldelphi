class DateField(tk.Frame):
    def __init__(self, parent, var, **kw):
        super().__init__(parent, bg=parent["bg"], **kw)
        self.var = var
        self.entry = make_entry(self, var, width=16)
        self.entry.pack(side="left", fill="x", expand=True)
        cal_btn = tk.Button(self, text="📅",
                            bg=BORDER, fg=ACCENT,
                            activebackground=ACCENT, activeforeground=BG,
                            relief="flat", cursor="hand2",
                            font=("Segoe UI", 10), padx=4,
                            command=self._open_cal)
        cal_btn.pack(side="left", padx=(2, 0))
        # Highlight entry on bad date
        self.entry.bind("<FocusOut>", self._validate)

    def _open_cal(self):
        DatePicker(self.entry, self.var)

    def _validate(self, event=None):
        val = self.var.get().strip()
        if val == "":
            self.entry.config(highlightbackground=BORDER)
        elif is_valid_date(val):
            self.entry.config(highlightbackground=ACCENT3)
        else:
            self.entry.config(highlightbackground=DANGER)

