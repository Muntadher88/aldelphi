    def _draw_bar_chart(self, parent, vs):
        """Canvas bar chart showing days until next oil change."""
        ch = 200
        cw = max(600, 80 * len(vs))
        cv = tk.Canvas(parent, bg=CARD, height=ch,
                        width=cw, highlightthickness=0)
        cv.pack(fill="x", padx=8, pady=12)

        if not vs:
            return

        bar_w   = min(60, int(cw / len(vs)) - 8)
        spacing = int(cw / len(vs))
        max_days = 100

        for i, v in enumerate(vs):
            d     = days_until(v.get("oilNextDate"))
            label = (v.get("vehicleNum") or v.get("vehicleName") or f"#{i+1}")[:8]
            x     = spacing * i + spacing // 2

            if d is None:
                color, bar_h = MUTED, 10
            elif d < 0:
                color, bar_h = DANGER, min(abs(d), max_days)
            elif d <= 7:
                color, bar_h = ACCENT, d
            else:
                color, bar_h = ACCENT3, min(d, max_days)

            bar_h_px = int((bar_h / max_days) * (ch - 50))
            bar_h_px = max(bar_h_px, 4)

            y1 = ch - 30 - bar_h_px
            y2 = ch - 30

            cv.create_rectangle(x - bar_w//2, y1,
                                 x + bar_w//2, y2,
                                 fill=color, outline="", width=0)

            # Day label on bar
            day_txt = str(d) if d is not None else "؟"
            cv.create_text(x, y1 - 6, text=day_txt,
                           fill=TEXT, font=("Segoe UI", 8, "bold"))
            # Vehicle label below
            cv.create_text(x, ch - 14, text=label,
                           fill=MUTED, font=("Segoe UI", 7),
                           angle=0)

        # Axis line
        cv.create_line(20, ch - 30, cw - 20, ch - 30,
                       fill=BORDER, width=1)
        cv.create_text(cw - 20, ch - 44,
                       text="الأيام المتبقية للتغيير (ألوان: 🟢 جيد  🟡 قريب  🔴 متأخر)",
                       fill=MUTED, font=("Segoe UI", 7), anchor="e")

    def _draw_summary_table(self, parent, vs):
        cols = ("الآلية", "الرقم", "السائق", "حالة الزيت", "متبقي(ي)", "حالة الفلتر", "متبقي(ي)")
        t = ttk.Treeview(parent, columns=cols, show="headings",
                          height=min(len(vs), 10))
        widths = [130, 110, 120, 120, 80, 120, 80]
        for c, w in zip(cols, widths):
            t.heading(c, text=c)
            t.column(c, width=w, anchor="center", minwidth=50)
        t.tag_configure("danger", foreground=DANGER)
        t.tag_configure("warn",   foreground=ACCENT)
        t.tag_configure("ok",     foreground=ACCENT3)

        for v in vs:
            ot, oc = status_text(v.get("oilNextDate", ""))
            ft, fc = status_text(v.get("filterNextDate", ""))
            od = days_until(v.get("oilNextDate"))
            fd = days_until(v.get("filterNextDate"))
            tag = "danger" if oc==DANGER or fc==DANGER else \
                  "warn"   if oc==ACCENT  or fc==ACCENT  else "ok"
            t.insert("", "end",
                     values=(v.get("vehicleName","-"),
                             v.get("vehicleNum","-"),
                             v.get("driverName","-"),
                             ot, str(od) if od is not None else "—",
                             ft, str(fd) if fd is not None else "—"),
                     tags=(tag,))
        t.pack(fill="x", padx=8, pady=8)

    def _draw_type_breakdown(self, parent, vs):
        from collections import Counter
        counts = Counter(v.get("vehicleType") or "غير محدد" for v in vs)
        frm = tk.Frame(parent, bg=CARD)
        frm.pack(padx=16, pady=12, fill="x")
        for typ, cnt in sorted(counts.items(), key=lambda x: -x[1]):
            row = tk.Frame(frm, bg=CARD)
            row.pack(fill="x", pady=3)
            tk.Label(row, text=typ, bg=CARD, fg=TEXT,
                     font=("Segoe UI", 9, "bold"), width=14,
                     anchor="e").pack(side="left", padx=8)
            bar_f = tk.Frame(row, bg=CARD2, height=18)
            bar_f.pack(side="left", fill="x", expand=True)
            bar_f.pack_propagate(False)
            pct = cnt / len(vs)
            bar_inner = tk.Frame(bar_f, bg=ACCENT2, height=18,
                                  width=int(pct * 300))
            bar_inner.place(x=0, y=0, relheight=1.0,
                            relwidth=pct)
            tk.Label(row, text=f"{cnt}  ({pct:.0%})",
                     bg=CARD, fg=MUTED,
                     font=("Segoe UI", 8)).pack(side="left", padx=8)

