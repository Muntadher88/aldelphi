        for lbl, var in [("كلمة المرور الحالية", op),
                          ("كلمة المرور الجديدة", np1),
                          ("تأكيد كلمة المرور الجديدة", np2)]:
            tk.Label(inn, text=lbl, bg=CARD, fg=MUTED,
                     font=("Segoe UI", 8, "bold")).pack(anchor="w")
