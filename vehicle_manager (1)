        box = card_frame(outer)
        box.pack(fill="x")
        inner = tk.Frame(box, bg=CARD)
        inner.pack(padx=26, pady=26, fill="x")

        def field(label, var, show=""):
            tk.Label(inner, text=label, bg=CARD, fg=MUTED,
                     font=("Segoe UI", 8, "bold"),
                     anchor="w").pack(fill="x")
            e = make_entry(inner, var, width=32, show=show)
            e.pack(fill="x", pady=(3, 12))
            return e

        self.u_var = tk.StringVar()
        self.p_var = tk.StringVar()
        ue = field("👤  اسم المستخدم", self.u_var)
        pe = field("🔒  كلمة المرور",  self.p_var, show="●")

        ue.bind("<Return>", lambda e: pe.focus())
        pe.bind("<Return>", lambda e: self._do_login())

        make_btn(inner, "🔐  تسجيل الدخول", self._do_login,
                 width=32, size=11).pack(fill="x", pady=4)

        self.err = tk.Label(inner, text="", bg=CARD, fg=DANGER,
                            font=("Segoe UI", 9), wraplength=320)
        self.err.pack(pady=(4, 0))

        tk.Label(outer,
                 text="نظام إدارة الآليات والصيانة  ·  الإصدار 2.0",
                 bg=BG, fg="#2d3748",
                 font=("Segoe UI", 8)).pack(pady=10)
        ue.focus()

    def _do_login(self):
        u = self.u_var.get().strip()
        p = self.p_var.get()
        if not u or not p:
            self.err.config(text="⚠️ يرجى إدخال اسم المستخدم وكلمة المرور")
            return
        found = next((x for x in load_users()
                      if x["username"] == u and x["password"] == p), None)
        if not found:
            self.err.config(text="❌ اسم المستخدم أو كلمة المرور غير صحيحة")
            self.p_var.set("")
            return
        self.win.destroy()
        self.on_success(found)

