    def _sort_by(self, col):
        """Sort treeview by column header click."""
        if self._sort_col == col:
            self._sort_rev = not self._sort_rev
        else:
            self._sort_col = col
            self._sort_rev = False
        self._refresh_table()

    def _refresh_table(self):
        self.tree.delete(*self.tree.get_children())

        q      = self.search_var.get().lower().strip()
        ftype  = self.filter_type_var.get() if hasattr(self, "filter_type_var") else "الكل"
        fstatus = self.filter_status_var.get() if hasattr(self, "filter_status_var") else "الكل"

        filtered_idx = []
        for i, v in enumerate(self.vehicles):
            # Text search
            if q and not any(q in (v.get(k) or "").lower()
                             for k in ("driverName","vehicleNum","vehicleName","notes")):
                continue
            # Type filter
            if ftype and ftype != "الكل" and v.get("vehicleType") != ftype:
                continue
            # Status filter
            if fstatus != "الكل":
                ot = status_tag(v.get("oilNextDate"))
                ft = status_tag(v.get("filterNextDate"))
                worst = "danger" if "danger" in (ot, ft) else \
                        "warn"   if "warn"   in (ot, ft) else "ok"
                if fstatus == "متأخر"        and worst != "danger": continue
                if fstatus == "يستحق قريباً" and worst != "warn":   continue
                if fstatus == "جيد"          and worst != "ok":      continue
            filtered_idx.append(i)

        # Sort
        if self._sort_col:
            col_map = {
                "#": None, "السائق": "driverName", "النوع": "vehicleType",
                "الآلية": "vehicleName", "الرقم": "vehicleNum",
            }
            key = col_map.get(self._sort_col)
            if key:
                filtered_idx.sort(
                    key=lambda i: (self.vehicles[i].get(key) or "").lower(),
                    reverse=self._sort_rev)

        for row_num, real_i in enumerate(filtered_idx):
            v       = self.vehicles[real_i]
            oil_t, oil_c = status_text(v.get("oilNextDate", ""))
            flt_t, flt_c = status_text(v.get("filterNextDate", ""))

            base_tag = "danger" if oil_c == DANGER or flt_c == DANGER else \
                       "warn"   if oil_c == ACCENT  or flt_c == ACCENT  else "ok"
            tag = base_tag + ("_b" if row_num % 2 else "")

            def fmt_l(val, unit):
                return f"{val} {unit}" if val else "-"

            row_data = (
                row_num + 1,
                v.get("driverName", "-")  or "-",
                v.get("vehicleType", "-") or "-",
                v.get("vehicleName", "-") or "-",
                v.get("vehicleNum",  "-") or "-",
                fmt_l(v.get("oilWithFilter"),    "ل"),
                fmt_l(v.get("oilWithoutFilter"), "ل"),
                v.get("oilGrade",       "-") or "-",
                fmt_l(v.get("fuelQty"), "ل/يوم"),
                v.get("oilChangeDate",    "-") or "-",
                v.get("oilNextDate",      "-") or "-",
                oil_t,
                v.get("filterChangeDate", "-") or "-",
                v.get("filterNextDate",   "-") or "-",
                flt_t,
                v.get("notes", "-") or "-",
            )
            # BUG FIX: store real index in iid
            self.tree.insert("", "end",
                             iid=str(real_i),
                             values=row_data,
                             tags=(tag,))

        count = len(filtered_idx)
        total = len(self.vehicles)
        self._count_lbl.config(
            text=f"عرض {count} من {total} آلية"
            + ("  ← انقر على العنوان للترتيب" if total else ""))
        self._update_status()

    def _delete_vehicle(self):
        sel = self.tree.selection()
        if not sel:
            messagebox.showwarning("تنبيه", "يرجى تحديد آلية أولاً")
            return
        real_i = int(sel[0])
        v      = self.vehicles[real_i]
        if messagebox.askyesno("تأكيد الحذف",
                f"هل تريد حذف الآلية:\n\n"
                f"  {v.get('vehicleName','-')}  ({v.get('vehicleNum','-')})\n"
                f"  السائق: {v.get('driverName','-')}\n\n"
                "لا يمكن التراجع عن هذا الإجراء."):
            self.vehicles.pop(real_i)
            save_vehicles(self.vehicles)
            self._refresh_all()

