            return
        ts   = datetime.now().strftime("%Y%m%d_%H%M%S")
        path = os.path.join(DATA_DIR, f"vehicles_export_{ts}.csv")
        try:
            headers = [
                "م", "اسم السائق", "نوع الآلية", "اسم الآلية",
                "رقم الآلية", "زيت مع فلتر", "زيت بدون فلتر",
                "درجة الزيت", "وقود (ل/يوم)",
                "تغيير الزيت", "استحقاق الزيت", "حالة الزيت",
                "تغيير الفلتر", "استحقاق الفلتر", "حالة الفلتر",
                "ملاحظات", "تاريخ الإضافة"
            ]
            with open(path, "w", newline="", encoding="utf-8-sig") as f:
                w = csv.writer(f)
                w.writerow(headers)
                for i, v in enumerate(self.vehicles):
                    ot, _ = status_text(v.get("oilNextDate", ""))
                    ft, _ = status_text(v.get("filterNextDate", ""))
                    w.writerow([
                        i+1,
                        v.get("driverName", ""),
                        v.get("vehicleType", ""),
                        v.get("vehicleName", ""),
                        v.get("vehicleNum", ""),
                        v.get("oilWithFilter", ""),
                        v.get("oilWithoutFilter", ""),
                        v.get("oilGrade", ""),
                        v.get("fuelQty", ""),
                        v.get("oilChangeDate", ""),
                        v.get("oilNextDate", ""),
                        ot,
                        v.get("filterChangeDate", ""),
                        v.get("filterNextDate", ""),
                        ft,
                        v.get("notes", ""),
                        v.get("addedAt", "")[:10] if v.get("addedAt") else "",
                    ])
            messagebox.showinfo("تم التصدير",
                f"✅ تم تصدير {len(self.vehicles)} آلية إلى:\n{path}")
        except Exception as ex:
            messagebox.showerror("خطأ", f"فشل التصدير:\n{ex}")

    # ══════════════════════════════════════════════
    #  LOGOUT / CLOSE
    # ══════════════════════════════════════════════
    def _logout(self):
        if messagebox.askyesno("تأكيد", "هل تريد تسجيل الخروج؟"):
            self._do_logout()

    def _on_close(self):
        if messagebox.askyesno("تأكيد", "هل تريد إغلاق البرنامج؟"):
            self._do_logout()

    def _do_logout(self):
        self.root.destroy()
        main()

    # ══════════════════════════════════════════════
    #  REFRESH ALL
    # ══════════════════════════════════════════════
    def _refresh_all(self):
        self.vehicles = load_vehicles()   # reload from disk
        self._refresh_table()
        self._refresh_stats()
        self._refresh_notif()
        self._update_status()

