        msg_l = tk.Label(dlg, text="", bg=BG, font=("Segoe UI", 9))
        msg_l.pack()

        def save_pw():
            us = load_users()
            user = next((x for x in us
                         if x["username"] == self.current_user["username"]), None)
            if not user or user["password"] != op.get():
                msg_l.config(text="❌ كلمة المرور الحالية غير صحيحة", fg=DANGER)
                return
            if len(np1.get()) < 4:
                msg_l.config(text="⚠️ كلمة المرور الجديدة قصيرة جداً (4 أحرف على الأقل)", fg=ACCENT)
                return
            if np1.get() != np2.get():
                msg_l.config(text="❌ كلمة المرور الجديدة غير متطابقة", fg=DANGER)
                return
            user["password"] = np1.get()
            self.current_user["password"] = np1.get()
            save_users(us)
            msg_l.config(text="✅ تم تغيير كلمة المرور بنجاح", fg=ACCENT3)
