def days_until(date_str):
    if not date_str or str(date_str).strip() == "":
        return None
    try:
        d = datetime.strptime(str(date_str).strip(), "%Y-%m-%d").date()
        return (d - date.today()).days
    except Exception:
        return None

def is_valid_date(s):
    try:
        datetime.strptime(s.strip(), "%Y-%m-%d")
        return True
    except Exception:
        return False

def add_days_to_date(date_str, days):
    try:
        d = datetime.strptime(date_str.strip(), "%Y-%m-%d").date()
        return (d + timedelta(days=days)).strftime("%Y-%m-%d")
    except Exception:
        return ""

def status_text(date_str):
    d = days_until(date_str)
    if d is None:   return "غير محدد", MUTED
    if d < 0:       return f"متأخر {abs(d)} يوم", DANGER
    if d == 0:      return "اليوم!", WARN
    if d <= 7:      return f"بعد {d} أيام", ACCENT
    return f"بعد {d} يوم", ACCENT3

def status_tag(date_str):
    d = days_until(date_str)
    if d is None:        return "ok"
    if d < 0:            return "danger"
    if d <= 7:           return "warn"
    return "ok"

