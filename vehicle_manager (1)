class DatePicker(tk.Toplevel):
    """Simple clickable calendar popup that sets a StringVar."""
    def __init__(self, parent, var):
        super().__init__(parent)
        self.var = var
        self.configure(bg=CARD)
        self.overrideredirect(True)
        self.resizable(False, False)
        try:
            d = datetime.strptime(var.get().strip(), "%Y-%m-%d").date()
            self._year, self._month = d.year, d.month
        except Exception:
            today = date.today()
            self._year, self._month = today.year, today.month
        self._build()
        self._position(parent)
        self.grab_set()
        self.focus_force()
        self.bind("<Escape>", lambda e: self.destroy())

    def _position(self, parent):
        self.update_idletasks()
        x = parent.winfo_rootx()
        y = parent.winfo_rooty() + parent.winfo_height() + 4
        self.geometry(f"+{x}+{y}")

    def _build(self):
        for w in self.winfo_children():
            w.destroy()

        # Header
        hdr = tk.Frame(self, bg=HDR)
        hdr.pack(fill="x")
        make_btn(hdr, "◀", self._prev_month,
                 color=HDR, fg=ACCENT, width=3, size=11).pack(side="left", padx=4, pady=6)
        tk.Label(hdr,
                 text=f"{calendar.month_name[self._month]} {self._year}",
                 bg=HDR, fg=ACCENT,
                 font=("Segoe UI", 11, "bold")).pack(side="left", expand=True)
        make_btn(hdr, "▶", self._next_month,
                 color=HDR, fg=ACCENT, width=3, size=11).pack(side="right", padx=4, pady=6)

        # Day names
        days_row = tk.Frame(self, bg=CARD)
        days_row.pack(fill="x", padx=4)
        for d in ["Su", "Mo", "Tu", "We", "Th", "Fr", "Sa"]:
            tk.Label(days_row, text=d, bg=CARD, fg=MUTED,
                     font=("Segoe UI", 8, "bold"), width=4).pack(side="left")

        # Separator
        ttk.Separator(self, orient="horizontal").pack(fill="x")

        # Calendar grid
        grid = tk.Frame(self, bg=CARD)
        grid.pack(padx=4, pady=4)

        cal  = calendar.monthcalendar(self._year, self._month)
        today = date.today()
        try:
            sel  = datetime.strptime(self.var.get().strip(), "%Y-%m-%d").date()
        except Exception:
            sel  = None

        for week in cal:
            row_f = tk.Frame(grid, bg=CARD)
            row_f.pack()
            for day in week:
                if day == 0:
                    tk.Label(row_f, text="", bg=CARD, width=4, height=2).pack(side="left")
                else:
                    d_date = date(self._year, self._month, day)
                    is_today = d_date == today
                    is_sel   = d_date == sel
                    bg   = ACCENT  if is_sel   else (ACCENT2 if is_today else CARD2)
                    fg   = BG      if is_sel   else (TEXT    if is_today else TEXT)
                    cell = tk.Button(row_f, text=str(day),
                                     bg=bg, fg=fg,
                                     activebackground=ACCENT, activeforeground=BG,
                                     relief="flat", cursor="hand2", width=4, height=2,
                                     font=("Segoe UI", 9),
                                     command=lambda d=d_date: self._pick(d))
                    cell.pack(side="left", padx=1, pady=1)

        # Today button
        make_btn(self, "📅 اليوم", lambda: self._pick(date.today()),
                 color=BORDER, fg=TEXT, size=9).pack(fill="x", padx=4, pady=(2, 4))

    def _prev_month(self):
        if self._month == 1:  self._month, self._year = 12, self._year - 1
        else:                 self._month -= 1
        self._build()

    def _next_month(self):
        if self._month == 12: self._month, self._year = 1, self._year + 1
        else:                 self._month += 1
        self._build()

    def _pick(self, d):
        self.var.set(d.strftime("%Y-%m-%d"))
        self.destroy()

