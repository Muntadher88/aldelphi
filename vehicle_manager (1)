    def _build_grid(self, parent, fields, var_dict, cols=2):
        # BUG FIX: loop instead of passing list to columnconfigure
        for c in range(cols):
            parent.columnconfigure(c, weight=1)

        for i, f in enumerate(fields):
            r, c = divmod(i, cols)
            cell = tk.Frame(parent, bg=CARD)
            cell.grid(row=r, column=c, padx=8, pady=6, sticky="nsew")

            label, key, kind = f[0], f[1], f[2]
            tk.Label(cell, text=label, bg=CARD, fg=MUTED,
                     font=("Segoe UI", 8, "bold")).pack(anchor="w", pady=(0, 3))

            var = tk.StringVar()
            var_dict[key] = var

            if kind == "entry":
                make_entry(cell, var, width=26).pack(fill="x")
            elif kind == "combo":
                make_combo(cell, f[3], var, width=24).pack(fill="x")
            elif kind == "date":
                DateField(cell, var).pack(fill="x")

    def _auto_calc_dates(self):
        iv = self._auto_interval_var.get()
        if not iv:
            return
        days_map = {"30 يوم": 30, "60 يوم": 60, "90 يوم": 90,
                    "180 يوم": 180, "365 يوم": 365}
        days = days_map.get(iv, 0)
        if not days:
            return
        ocd = self.add_vars["oilChangeDate"].get().strip()
        fcd = self.add_vars["filterChangeDate"].get().strip()
        if ocd and is_valid_date(ocd):
            self.add_vars["oilNextDate"].set(add_days_to_date(ocd, days))
        if fcd and is_valid_date(fcd):
            self.add_vars["filterNextDate"].set(add_days_to_date(fcd, days))

    def _add_vehicle(self):
        av = self.add_vars
        driver = av["driverName"].get().strip()
        name   = av["vehicleName"].get().strip()
        num    = av["vehicleNum"].get().strip()

        if not driver or not name or not num:
            messagebox.showwarning("حقول مطلوبة",
                "⚠️ يرجى إدخال:\n• اسم السائق\n• اسم الآلية\n• رقم الآلية")
            return

        # Validate dates
        for dk in ("oilChangeDate", "oilNextDate", "filterChangeDate", "filterNextDate"):
            val = av[dk].get().strip()
            if val and not is_valid_date(val):
                messagebox.showwarning("تاريخ غير صحيح",
                    f"⚠️ التاريخ في حقل '{dk}' غير صحيح.\nاستخدم الصيغة: YYYY-MM-DD")
                return

        # Check duplicate
        if any(v["vehicleNum"] == num for v in self.vehicles):
            if not messagebox.askyesno("تكرار",
                f"⚠️ يوجد آلية برقم '{num}' مسبقاً.\nهل تريد الإضافة على أي حال؟"):
                return

        v = {k: vr.get().strip() for k, vr in av.items()}
        v["addedAt"] = datetime.now().isoformat()
        self.vehicles.append(v)
        save_vehicles(self.vehicles)
        self._clear_add_form()
        self._refresh_all()
        messagebox.showinfo("تم الحفظ", "✅ تم حفظ بيانات الآلية بنجاح!")
        self.nb.select(1)

    def _clear_add_form(self):
        for v in self.add_vars.values():
            v.set("")

    def _copy_last(self):
        if not self.vehicles:
            messagebox.showinfo("تنبيه", "لا توجد آليات مسجلة بعد.")
            return
        last = self.vehicles[-1]
        for k, v in self.add_vars.items():
            if k not in ("vehicleNum", "driverName", "addedAt"):
                v.set(last.get(k, "") or "")
        messagebox.showinfo("تم", "تم نسخ بيانات الآلية الأخيرة (ما عدا الاسم والرقم)")

