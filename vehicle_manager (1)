        def _auto(d_map={"30 يوم":30,"60 يوم":60,"90 يوم":90,"180 يوم":180,"365 يوم":365}):
            days = d_map.get(aiv.get(), 0)
            if not days: return
            for cd, nd in (("oilChangeDate","oilNextDate"),
                           ("filterChangeDate","filterNextDate")):
                s = edit_vars[cd].get().strip()
                if s and is_valid_date(s):
                    edit_vars[nd].set(add_days_to_date(s, days))
        make_btn(ac_row, "⚙️ تطبيق", _auto, color=ACCENT2, fg="#fff", size=8).pack(side="left")

        def save_edit():
            # Validate required
            if not edit_vars["driverName"].get().strip() or \
               not edit_vars["vehicleName"].get().strip() or \
               not edit_vars["vehicleNum"].get().strip():
                messagebox.showwarning("حقول مطلوبة",
                    "⚠️ اسم السائق واسم الآلية ورقمها مطلوبة",
                    parent=dlg)
                return
            for dk in ("oilChangeDate","oilNextDate","filterChangeDate","filterNextDate"):
                val = edit_vars[dk].get().strip()
                if val and not is_valid_date(val):
                    messagebox.showwarning("تاريخ غير صحيح",
                        f"⚠️ التاريخ في '{dk}' غير صحيح", parent=dlg)
                    return
            self.vehicles[real_i] = {
                **self.vehicles[real_i],
                **{k: ev.get().strip() for k, ev in edit_vars.items()}
            }
            save_vehicles(self.vehicles)
            self._refresh_all()
            dlg.destroy()
            messagebox.showinfo("تم", "✅ تم حفظ التعديلات بنجاح")

        btn_row = tk.Frame(wrap, bg=BG)
        btn_row.pack(pady=14)
        make_btn(btn_row, "💾  حفظ التعديلات", save_edit,
                 color=ACCENT, fg=BG).pack(side="left", padx=6)
        make_btn(btn_row, "❌  إلغاء (Esc)", dlg.destroy,
                 color=CARD2, fg=TEXT).pack(side="left", padx=6)

