def make_entry(parent, var=None, width=24, show="", readonly=False):
    state = "readonly" if readonly else "normal"
    e = tk.Entry(parent, textvariable=var, width=width,
                 bg=INP, fg=TEXT, insertbackground=ACCENT,
                 relief="flat", bd=0,
                 highlightthickness=1,
                 highlightbackground=BORDER,
                 highlightcolor=ACCENT,
                 disabledbackground=CARD2,
                 disabledforeground=MUTED,
                 font=("Segoe UI", 10),
                 show=show)
    if readonly:
        e.config(state="readonly")
    return e

def make_combo(parent, values, var, width=22):
    c = ttk.Combobox(parent, values=values, textvariable=var,
                     width=width, state="readonly",
                     font=("Segoe UI", 10))
    c.option_add("*TCombobox*Listbox.background", CARD)
    c.option_add("*TCombobox*Listbox.foreground", TEXT)
    c.option_add("*TCombobox*Listbox.selectBackground", BORDER)
    c.option_add("*TCombobox*Listbox.font", ("Segoe UI", 10))
    return c

def make_btn(parent, text, cmd, color=ACCENT, fg=BG, width=None, size=10):
    kw = {}
    if width: kw["width"] = width
    b = tk.Button(parent, text=text, command=cmd,
                  bg=color, fg=fg,
                  activebackground=color, activeforeground=fg,
                  relief="flat", cursor="hand2",
                  font=("Segoe UI", size, "bold"),
                  padx=12, pady=7, **kw)
    # Hover effect
    b.bind("<Enter>", lambda e: b.config(bg=_lighten(color)))
    b.bind("<Leave>", lambda e: b.config(bg=color))
    return b

def _lighten(hex_color):
    """Return a slightly lighter version of hex color."""
    try:
        r = int(hex_color[1:3], 16)
        g = int(hex_color[3:5], 16)
        b = int(hex_color[5:7], 16)
        r = min(255, r + 25)
        g = min(255, g + 25)
        b = min(255, b + 25)
        return f"#{r:02x}{g:02x}{b:02x}"
    except Exception:
        return hex_color

def card_frame(parent, bg=CARD, **kw):
    return tk.Frame(parent, bg=bg, relief="flat",
                    highlightthickness=1,
                    highlightbackground=BORDER, **kw)

def bind_mousewheel(widget, canvas):
    """Bind mousewheel to scroll a canvas — cross-platform."""
    def _scroll(event):
        if event.num == 4 or event.delta > 0:
            canvas.yview_scroll(-1, "units")
        elif event.num == 5 or event.delta < 0:
            canvas.yview_scroll(1, "units")
    widget.bind("<MouseWheel>", _scroll)     # Windows / Mac
    widget.bind("<Button-4>",   _scroll)     # Linux scroll up
    widget.bind("<Button-5>",   _scroll)     # Linux scroll down

def scrollable_frame(parent):
    """Return (outer_frame, inner_frame, canvas) — ready for content."""
    outer  = tk.Frame(parent, bg=BG)
    canvas = tk.Canvas(outer, bg=BG, highlightthickness=0)
    vsb    = ttk.Scrollbar(outer, orient="vertical", command=canvas.yview)
    canvas.configure(yscrollcommand=vsb.set)
    vsb.pack(side="right", fill="y")
    canvas.pack(side="left", fill="both", expand=True)
    inner  = tk.Frame(canvas, bg=BG)
    win_id = canvas.create_window((0, 0), window=inner, anchor="nw")

    def _on_inner(e):
        canvas.configure(scrollregion=canvas.bbox("all"))
    def _on_canvas(e):
        canvas.itemconfig(win_id, width=e.width)
        canvas.configure(scrollregion=canvas.bbox("all"))

    inner.bind("<Configure>", _on_inner)
    canvas.bind("<Configure>", _on_canvas)
    bind_mousewheel(canvas, canvas)
    bind_mousewheel(inner,  canvas)
    return outer, inner, canvas

